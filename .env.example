# Kết nối Postgres (Neon/Vercel Postgres...) — dạng: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# Chuỗi bí mật ngẫu nhiên để ký session JWT — tạo bằng: openssl rand -base64 32
SESSION_SECRET=

# API key từ tài khoản Resend (resend.com/api-keys)
RESEND_API_KEY=
# Địa chỉ gửi email — dùng onboarding@resend.dev nếu chưa xác minh domain riêng
RESEND_FROM_EMAIL=onboarding@resend.dev

# Domain gốc của app (dùng để tạo link đặt lại mật khẩu) — để trống ở local,
# Vercel sẽ tự set khi deploy.
APP_URL=http://localhost:3000
